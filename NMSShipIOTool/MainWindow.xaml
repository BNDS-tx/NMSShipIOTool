<Window
    x:Class="NMSShipIOTool.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="12" MinWidth="1000" MinHeight="680">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <NavigationView
            x:Name="NavRoot"
            Grid.Row="0"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            SelectionFollowsFocus="Disabled"
            AlwaysShowHeader="False"
            OpenPaneLength="160">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="NavItem1">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Home" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavItem2" IsEnabled="False">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xF581;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavItem3" IsEnabled="False">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE709;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <ContentControl
                x:Name="PageContent"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                Padding="10"/>
        </NavigationView>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <ProgressBar x:Name="progressBar" Width="145" Height="32" IsIndeterminate="True" Visibility="Collapsed" />
                <Button x:Name="langButton" MinWidth="100" MinHeight="40">
                    <Button.Flyout>
                        <MenuFlyout Placement="Top">
                            <ToggleMenuFlyoutItem x:Name="langMenuEN" Text="English" />
                            <ToggleMenuFlyoutItem x:Name="langMenuZH" Text="简体中文" />
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
                <Button x:Name="aboutButton" MinWidth="100" MinHeight="40" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
