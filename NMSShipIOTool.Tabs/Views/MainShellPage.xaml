<UserControl
    x:Class="NMSShipIOTool.Views.MainShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:NMSShipIOTool.Views"
    mc:Ignorable="d">

    <Grid Padding="12" RowSpacing="10" ColumnSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabView x:Name="TabRoot" Grid.Row="0" VerticalAlignment="Stretch" IsAddTabButtonVisible="False">
            <TabViewItem x:Name="TabPage1Item">
                <views:LoadTabPage x:Name="LoadTab" />
            </TabViewItem>
            <TabViewItem x:Name="TabPage2Item" IsEnabled="False">
                <views:ImportTabPage x:Name="ImportTab" />
            </TabViewItem>
            <TabViewItem x:Name="TabPage3Item" IsEnabled="False">
                <views:SeedTabPage x:Name="SeedTab" />
            </TabViewItem>
        </TabView>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ProgressBar
                x:Name="progressBar"
                Grid.Column="1"
                Width="145"
                Height="32"
                IsIndeterminate="True"
                Visibility="Collapsed" />
            <Button
                x:Name="aboutButton"
                Grid.Column="2"
                MinWidth="100"
                MinHeight="40" />
        </Grid>
    </Grid>
</UserControl>
